                        <Icon name="lucide:twitter" class="w-5 h-5" />
                    </a>
                    <a
                        href="#"
                        class="btn btn-circle btn-sm btn-ghost hover:bg-primary/20 hover:text-primary transition-colors"
                        aria-label="Instagram"
                    >
                        <Icon name="lucide:instagram" class="w-5 h-5" />
                    </a>
                    <a
                        href="#"
                        class="btn btn-circle btn-sm btn-ghost hover:bg-primary/20 hover:text-primary transition-colors"
                        aria-label="Github"
                    >
                        <Icon name="lucide:github" class="w-5 h-5" />
                    </a>
                </div> -->
      </div>

      <!-- Links Column 1 -->
      <div>
        <h3 class="font-bold text-lg mb-6 text-base-content/90">Tienda</h3>
        <ul class="space-y-4">
          <li>
            <a
              href="/shop"
              class="text-base-content/60 hover:text-primary hover:translate-x-1 transition-all inline-block"
              >Todos los productos</a
            >
          </li>
          <li>
            <a
              href="/shop/featured"
              class="text-base-content/60 hover:text-primary hover:translate-x-1 transition-all inline-block"
              >Destacados</a
            >
          </li>
          <li>
            <a
              href="/shop/new-arrivals"
              class="text-base-content/60 hover:text-primary hover:translate-x-1 transition-all inline-block"
              >Nuevos Productos</a
            >
          </li>
          <li>
            <a
              href="/shop/sale"
              class="text-base-content/60 hover:text-primary hover:translate-x-1 transition-all inline-block"
              >Ofertas</a
            >
          </li>
        </ul>
      </div>

      <!-- Links Column 2 -->
      <div>
        <h3 class="font-bold text-lg mb-6 text-base-content/90">Soporte</h3>
        <ul class="space-y-4">
          <li>
            <a
              href="/contact"
              class="text-base-content/60 hover:text-primary hover:translate-x-1 transition-all inline-block"
