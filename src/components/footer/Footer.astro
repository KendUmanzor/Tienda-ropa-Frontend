    </div>

    <div
      class="border-t border-base-content/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-base-content/50"
    >
      <p>
        &copy; {new Date().getFullYear()} ESIGNA Streetwear. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

<style>
  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary) 0%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
