---
import AboutCard from "./AboutCard.astro";

const values = [
    {
        title: "Calidad Inigualable",
        description:
            "Seleccionamos las mejores marcas de ropa streetwear para ofrecerte productos que combinan estilo y durabilidad, garantizando que cada compra sea una inversión en tu guardarropa.",
        icon: "lucide:award",
    },
    {
        title: "Envío Rápido y Seguro",
        description:
            "Logística de vanguardia para garantizar que tu ropa premium llegue de manera segura y rápida, en cualquier lugar del mundo.",
        icon: "lucide:truck",
    },
    {
        title: "Soporte Experto",
        description:
            "Nuestro equipo de especialistas en tecnología está disponible 24/7 para ayudarte a encontrar el dispositivo perfecto para tus necesidades.",
        icon: "lucide:headset",
    },
];
---

<section class="py-20 bg-slate-50 px-4">
    <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <span
                class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block"
                >Nuestros Valores</span
            >
            <h2
                class="text-3xl md:text-5xl font-black text-slate-900 uppercase"
            >
                Lo que nos mueve hacia adelante
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {values.map((value) => <AboutCard {...value} />)}
        </div>
    </div>
</section>
